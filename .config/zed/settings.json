{
  "icon_theme": "Material Icon Theme",

  "auto_update_extensions": {
    "material-icon-theme": true,
  },

  "cli_default_open_behavior": "existing_window",
  "autosave": "on_focus_change",

  "project_panel": {
    "dock": "left",
  },

  "outline_panel": {
    "dock": "left",
  },

  "collaboration_panel": {
    "dock": "left",
  },

  "agent": {
    "dock": "right",
  },

  "git_panel": {
    "dock": "left",
  },

  "title_bar": {
    "show_sign_in": false,
  },

  "debugger": {
    "button": true,
  },

  "diagnostics": {
    "button": true,
  },

  "disable_ai": true,

  "buffer_font_family": "Inconsolata Nerd Font Propo",
  "ui_font_size": 16,
  "buffer_font_size": 24,

  "session": {
    "trust_all_worktrees": true,
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Dracula",
  },

  "cursor_blink": false,
  "file_icons": true,

  "format_on_save": true,
}
